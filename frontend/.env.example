# API backend (apps/api)
REACT_APP_API_URL=http://localhost:8000

# Website-only Google OAuth (Web application client — NOT the extension client)
# Create in Google Cloud → Credentials → OAuth client ID → Web application
# Authorized JavaScript origin: http://localhost:3000
REACT_APP_GOOGLE_CLIENT_ID=your-website-web-client-id.apps.googleusercontent.com
