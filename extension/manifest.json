{
  "manifest_version": 3,
  "minimum_chrome_version": "116",
  "name": "KRAI Meeting Assistant",
  "version": "2.3.0",
  "description": "Record browser meetings with consent, upload securely, and open AI meeting reports.",
  "permissions": ["storage", "unlimitedStorage", "activeTab", "scripting", "tabCapture", "offscreen", "notifications", "identity"],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://teams.microsoft.com/*",
    "https://teams.live.com/*",
    "https://*.zoom.us/*",
    "http://localhost:8000/*",
    "http://localhost:3000/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "KRAI Meeting Assistant"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "options_page": "options.html",
  "oauth2": {
    "client_id": "549582331273-mckacm0dumj0gb6av5citfra2h0rndin.apps.googleusercontent.com",
    "scopes": ["openid", "email", "profile"]
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content/meet.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://teams.microsoft.com/*", "https://teams.live.com/*"],
      "js": ["content/teams.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.zoom.us/*"],
      "js": ["content/zoom.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
