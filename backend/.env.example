# Backend port (Render sets PORT automatically)
PORT=10000
ENV=local

# CORS — comma-separated origins (required for Render + Vercel)
# Example: https://your-app.vercel.app,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# Your deployed URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:10000

# Local Whisper (free speech-to-text)
WHISPER_MODEL=base
WHISPER_DEVICE=cpu

# Speaker diarization (free — needs HuggingFace token)
# 1. Create token at https://huggingface.co/settings/tokens
# 2. Accept license at https://huggingface.co/pyannote/speaker-diarization-3.1
ENABLE_DIARIZATION=true
HF_TOKEN=

# Local Ollama (free LLM) — run: ollama pull mistral
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
